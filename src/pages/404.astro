---
export const prerender = true;
import { t } from '../i18n';
import Layout from '../layouts/Layout.astro';

const uk = t('uk');
const en = t('en');
---

<Layout lang="uk" title={uk.notFound.metaTitle} description={uk.notFound.text} noIndex>
  <section class="mx-auto flex w-full max-w-2xl flex-col items-center px-5 py-24 text-center md:py-32">
    <p class="font-display text-6xl font-bold text-accent">404</p>
    <h1 class="mt-6 text-h2 font-bold tracking-tight">{uk.notFound.title}</h1>
    <p class="mt-4 text-lg text-muted">{uk.notFound.text}</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center justify-center rounded-full bg-accent px-7 py-3.5 font-medium text-white transition-colors hover:bg-accent-deep"
        >{uk.notFound.back}</a
      >
      <a
        href="/en/"
        class="inline-flex items-center justify-center rounded-full border border-line bg-card px-7 py-3.5 font-medium text-muted transition-colors hover:border-accent hover:text-accent"
        >{en.notFound.back}</a
      >
    </div>
  </section>
</Layout>
