---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { pick, t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  entry: CollectionEntry<'cases'>;
  // wide: ширша картка в асиметричному ряду. Обрізаємо прев'ю зверху,
  // щоб його висота збіглася з вужчою карткою поруч (лише на desktop).
  wide?: boolean;
}

const { lang, entry, wide = false } = Astro.props;
const dict = t(lang);
const { data } = entry;
const featured = data.featured;
const href = lang === 'en' ? `/en/cases/${entry.id}/` : `/cases/${entry.id}/`;

const niche = `${pick(lang, data.business.niche)} · ${pick(lang, data.business.city)}`;
const title = pick(lang, data.result);

const cardShell =
  'reveal group relative overflow-hidden rounded-3xl border border-line shadow-[var(--shadow-card)] transition-[transform,box-shadow] duration-300 hover:-translate-y-1.5 hover:shadow-[var(--shadow-lift)] focus-within:-translate-y-1.5 focus-within:shadow-[var(--shadow-lift)]';
const coverLink =
  'absolute inset-0 z-10 rounded-3xl focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2';
const ariaLabel = `${dict.cases.open}: ${data.business.name}`;
---

{
  featured ? (
    <Fragment>
      {/* Mobile: звичайна картка, як у решти робіт */}
      <article class:list={[cardShell, 'flex cursor-pointer flex-col bg-card sm:hidden']}>
        <div class="relative overflow-hidden">
          <Image
            src={data.cover}
            alt={data.business.name}
            widths={[400, 640, 900]}
            sizes="100vw"
            class="aspect-[2/1] w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
            loading="lazy"
          />
        </div>
        <div class="flex grow flex-col gap-1 px-4 pt-3 pb-4">
          <p class="text-sm font-medium text-muted">{niche}</p>
          <p class="text-h3 leading-snug font-semibold text-balance">{title}</p>
          <span
            aria-hidden="true"
            class="mt-auto inline-flex items-center gap-1.5 pt-2 font-medium text-accent"
          >
            <span class="group-hover:underline">{dict.cases.open}</span>
            <span class="transition-transform group-hover:translate-x-0.5">→</span>
          </span>
        </div>
        <a href={href} class={coverLink} aria-label={ariaLabel} />
      </article>

      {/* Tablet + desktop: велика картка, контент притиснутий до правого краю */}
      <article class:list={[cardShell, 'hidden cursor-pointer sm:block']}>
        <div class="relative aspect-[11/4]">
          <Image
            src={data.cover}
            alt={data.business.name}
            widths={[768, 1100, 1600]}
            sizes="(min-width: 1024px) 1120px, 100vw"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
            loading="lazy"
          />
          <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-l from-ink/95 via-ink/55 to-transparent" />
          <div aria-hidden="true" class="absolute inset-y-0 right-0 w-1/2 bg-gradient-to-l from-ink/80 to-transparent" />
          <div class="absolute right-16 bottom-16 w-[380px] text-left">
            <p class="text-sm font-medium text-white/85">{niche}</p>
            <p class="mt-1 text-2xl leading-tight font-semibold text-balance text-white md:text-[2rem]">
              {title}
            </p>
            <span class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-white px-4 py-2 text-sm font-semibold text-accent shadow-sm">
              {dict.cases.open}
              <span class="transition-transform group-hover:translate-x-0.5">→</span>
            </span>
          </div>
        </div>
        <a href={href} class={coverLink} aria-label={ariaLabel} />
      </article>
    </Fragment>
  ) : (
    <article class:list={[cardShell, 'flex cursor-pointer flex-col bg-card']}>
      <div class="relative overflow-hidden">
        <Image
          src={data.cover}
          alt={data.business.name}
          widths={[400, 640, 900]}
          sizes="(min-width: 640px) 50vw, 100vw"
          class:list={[
            'aspect-[2/1] w-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-[1.04]',
            wide && 'lg:aspect-[22/9]',
          ]}
          loading="lazy"
        />
        <div
          aria-hidden="true"
          class="absolute inset-0 bg-gradient-to-t from-ink/10 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"
        />
      </div>
      <div class="flex grow flex-col gap-1 px-4 pt-3 pb-4">
        <p class="text-sm font-medium text-muted">{niche}</p>
        <p class="text-h3 leading-snug font-semibold text-balance">{title}</p>
        <span
          aria-hidden="true"
          class="mt-auto inline-flex items-center gap-1.5 pt-2 font-medium text-accent"
        >
          <span class="group-hover:underline">{dict.cases.open}</span>
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </span>
      </div>
      <a href={href} class={coverLink} aria-label={ariaLabel} />
    </article>
  )
}
