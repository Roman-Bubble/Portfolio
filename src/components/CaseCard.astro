---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { pick, t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  entry: CollectionEntry<'cases'>;
}

const { lang, entry } = Astro.props;
const dict = t(lang);
const { data } = entry;
const featured = data.featured;
const href = lang === 'en' ? `/en/cases/${entry.id}/` : `/cases/${entry.id}/`;

const cardShell =
  'reveal group relative overflow-hidden rounded-3xl border border-line shadow-[var(--shadow-card)] transition-[transform,box-shadow] duration-300 hover:-translate-y-1.5 hover:shadow-[var(--shadow-lift)] focus-within:-translate-y-1.5 focus-within:shadow-[var(--shadow-lift)]';
const coverLink =
  'absolute inset-0 z-10 rounded-3xl focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2';
---

{
  featured ? (
    <article class:list={[cardShell, 'cursor-pointer sm:col-span-2']}>
      <div class="relative aspect-[16/10] sm:aspect-[11/4]">
        <Image
          src={data.cover}
          alt={data.business.name}
          widths={[768, 1100, 1600]}
          sizes="(min-width: 1024px) 1120px, 100vw"
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
          loading="lazy"
        />
        <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/35 to-transparent" />
        <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-r from-ink/75 via-ink/10 to-transparent" />
        <div class="absolute inset-0 flex items-end">
          <div class="max-w-md p-6 md:max-w-lg md:p-8">
            <p class="text-sm font-medium text-white/80">
              {pick(lang, data.business.niche)} · {pick(lang, data.business.city)}
            </p>
            <p class="mt-1.5 text-[1.75rem] leading-tight font-semibold text-balance text-white md:text-[2rem]">
              {pick(lang, data.result)}
            </p>
            <span class="mt-4 inline-flex items-center gap-1.5 rounded-full bg-white px-4 py-2 text-sm font-semibold text-accent shadow-sm">
              {dict.cases.open}
              <span class="transition-transform group-hover:translate-x-0.5">→</span>
            </span>
          </div>
        </div>
      </div>
      <a href={href} class={coverLink} aria-label={`${dict.cases.open}: ${data.business.name}`} />
    </article>
  ) : (
    <article class:list={[cardShell, 'flex cursor-pointer flex-col bg-card']}>
      <div class="relative overflow-hidden">
        <Image
          src={data.cover}
          alt={data.business.name}
          widths={[400, 640, 900]}
          sizes="(min-width: 640px) 50vw, 100vw"
          class="aspect-[2/1] w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
          loading="lazy"
        />
        <div
          aria-hidden="true"
          class="absolute inset-0 bg-gradient-to-t from-ink/10 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"
        />
      </div>
      <div class="flex grow flex-col gap-1.5 p-4">
        <p class="text-sm font-medium text-muted">
          {pick(lang, data.business.niche)} · {pick(lang, data.business.city)}
        </p>
        <p class="text-h3 leading-snug font-semibold text-balance">{pick(lang, data.result)}</p>
        <p class="text-sm text-muted">{data.business.name}</p>
        <span
          aria-hidden="true"
          class="mt-auto inline-flex items-center gap-1.5 pt-3 font-medium text-accent"
        >
          <span class="group-hover:underline">{dict.cases.open}</span>
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </span>
      </div>
      <a href={href} class={coverLink} aria-label={`${dict.cases.open}: ${data.business.name}`} />
    </article>
  )
}
