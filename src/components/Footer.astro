---
import { SITE } from '../site.config.mjs';
import { t, type Lang } from '../i18n';
import LangSwitch from './LangSwitch.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = t(lang);
const home = lang === 'en' ? '/en/' : '/';
const fullName = lang === 'en' ? `${SITE.nameEn} ${SITE.surnameEn}` : `${SITE.name} ${SITE.surname}`;
const year = new Date().getFullYear();

const nav = [
  { label: dict.nav.cases, href: `${home}#cases` },
  { label: dict.nav.price, href: `${home}#offer` },
  { label: dict.nav.how, href: `${home}#how` },
];

// Телефон текстом не показуємо — лише месенджери, для яких заповнене посилання.
const messengers = [
  { label: 'Telegram', href: SITE.telegram },
  { label: 'WhatsApp', href: SITE.whatsapp },
  { label: 'Viber', href: SITE.viber },
].filter((m) => m.href);
---

<footer class="border-t border-line">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-6 px-5 py-10 md:flex-row md:items-start md:justify-between md:px-8">
    <div>
      <p class="font-bold">{fullName}</p>
      <p class="mt-1 text-sm text-muted">{dict.footer.line}</p>
    </div>
    <div class="flex flex-col gap-4 md:items-end">
      <nav class="flex flex-wrap gap-x-5 gap-y-2 text-sm font-medium text-muted">
        {nav.map((item) => (
          <a href={item.href} class="transition-colors hover:text-accent">{item.label}</a>
        ))}
      </nav>
      <div class="flex flex-wrap items-center gap-4">
        {messengers.map((m) => (
          <a href={m.href} class="text-sm font-medium text-muted transition-colors hover:text-accent">{m.label}</a>
        ))}
        <LangSwitch lang={lang} />
      </div>
    </div>
  </div>
  <div class="mx-auto w-full max-w-6xl px-5 pb-6 md:px-8">
    <p class="text-xs text-muted">© {year} {fullName}</p>
  </div>
</footer>
