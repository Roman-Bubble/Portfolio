---
import { SITE } from '../site.config.mjs';
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = t(lang);
const home = lang === 'en' ? '/en/' : '/';
const fullName = lang === 'en' ? `${SITE.nameEn} ${SITE.surnameEn}` : `${SITE.name} ${SITE.surname}`;
const year = new Date().getFullYear();

const nav = [
  { label: dict.nav.cases, href: `${home}#cases` },
  { label: dict.nav.price, href: `${home}#offer` },
  { label: dict.nav.how, href: `${home}#how` },
];

// Телефон текстом не показуємо — лише месенджери, для яких заповнене посилання.
const messengers = [
  { label: 'Telegram', href: SITE.telegram },
  { label: 'WhatsApp', href: SITE.whatsapp },
  { label: 'Viber', href: SITE.viber },
].filter((m) => m.href);

const linkClass = 'text-sm font-medium text-muted transition-colors hover:text-accent';
const colTitleClass = 'text-xs font-semibold tracking-wide text-muted/80 uppercase';
---

<footer class="border-t border-line">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-10 px-5 py-12 md:flex-row md:justify-between md:px-8">
    <div class="max-w-xs">
      <p class="font-bold">{fullName}</p>
      <p class="mt-1 text-sm text-muted">{dict.footer.line}</p>
    </div>

    <div class="grid grid-cols-2 gap-10 sm:gap-16">
      <div>
        <p class={colTitleClass}>{dict.footer.navTitle}</p>
        <ul class="mt-3 grid gap-2">
          {nav.map((item) => (
            <li>
              <a href={item.href} class={linkClass}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class={colTitleClass}>{dict.footer.contactTitle}</p>
        <ul class="mt-3 grid gap-2">
          {messengers.map((m) => (
            <li>
              <a href={m.href} class={linkClass}>{m.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="mx-auto w-full max-w-6xl px-5 pb-6 md:px-8">
    <p class="text-xs text-muted">© {year} {fullName}</p>
  </div>
</footer>
