---
import { SITE } from '../site.config.mjs';
import { t, type Lang } from '../i18n';
import LangSwitch from './LangSwitch.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = t(lang);
const fullName = lang === 'en' ? `${SITE.nameEn} ${SITE.surnameEn}` : `${SITE.name} ${SITE.surname}`;
const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-4 px-5 py-10 md:flex-row md:items-center md:justify-between md:px-8">
    <div>
      <p class="font-bold">{fullName}</p>
      <p class="mt-1 text-sm text-muted">{dict.footer.line}</p>
    </div>
    <div class="flex flex-wrap items-center gap-4">
      <a href={SITE.phoneHref} class="text-sm font-medium text-muted transition-colors hover:text-accent">{SITE.phone}</a>
      <a href={SITE.telegram} class="text-sm font-medium text-muted transition-colors hover:text-accent">Telegram</a>
      <LangSwitch lang={lang} />
    </div>
  </div>
  <div class="mx-auto w-full max-w-6xl px-5 pb-6 md:px-8">
    <p class="text-xs text-muted">© {year} {fullName}</p>
  </div>
</footer>
