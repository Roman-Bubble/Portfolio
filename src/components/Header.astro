---
import { SITE } from '../site.config.mjs';
import { t, type Lang } from '../i18n';
import LangSwitch from './LangSwitch.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = t(lang);
const home = lang === 'en' ? '/en/' : '/';
const fullName = lang === 'en' ? `${SITE.nameEn} ${SITE.surnameEn}` : `${SITE.name} ${SITE.surname}`;
const initials = lang === 'en' ? `${SITE.nameEn[0]}${SITE.surnameEn[0]}` : `${SITE.name[0]}${SITE.surname[0]}`;
---

<header
  data-header
  class="glass sticky top-0 z-50 border-b border-transparent transition-[border-color,box-shadow] duration-300 [&.is-scrolled]:border-line/70 [&.is-scrolled]:shadow-[0_10px_30px_-18px_rgba(10,47,36,0.4)]"
>
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-5 py-3 md:px-8">
    <a href={home} class="group inline-flex items-center gap-2.5">
      <span
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent font-display text-[0.8125rem] leading-none font-semibold tracking-tight text-bg/95 ring-1 ring-inset ring-white/10 transition-transform duration-300 group-hover:-translate-y-0.5"
        aria-hidden="true">{initials}</span
      >
      <span class="font-display text-lg font-semibold tracking-tight whitespace-nowrap">{fullName}</span>
    </a>

    <nav
      aria-label={lang === 'en' ? 'Main navigation' : 'Головна навігація'}
      class="hidden items-center gap-8 md:flex"
    >
      <a href={`${home}#cases`} class="navlink text-sm font-medium text-muted transition-colors hover:text-ink">{dict.nav.cases}</a>
      <a href={`${home}#offer`} class="navlink text-sm font-medium text-muted transition-colors hover:text-ink">{dict.nav.price}</a>
      <a href={`${home}#how`} class="navlink text-sm font-medium text-muted transition-colors hover:text-ink">{dict.nav.how}</a>
    </nav>

    <div class="flex items-center gap-3">
      <LangSwitch lang={lang} />
      <a href={`${home}#contact`} class="btn btn-primary hidden px-5 py-2.5 text-sm sm:inline-flex">
        {dict.nav.cta}
      </a>
    </div>
  </div>

  <div class="scroll-progress" aria-hidden="true">
    <span data-progress class="scroll-progress__bar"></span>
  </div>
</header>

<style>
  .navlink {
    position: relative;
  }
  .navlink::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 1.5px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.28s var(--ease-out);
  }
  .navlink:hover::after {
    transform: scaleX(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .navlink::after {
      transition: none;
    }
  }
</style>
