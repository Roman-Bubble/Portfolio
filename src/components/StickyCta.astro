---
import { SITE } from '../site.config.mjs';
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = t(lang);
---

<!-- Мобільна кнопка знизу: з'являється, коли hero пішов з екрана -->
<div class="md:hidden">
  <div
    id="sticky-cta"
    class="glass fixed inset-x-0 bottom-0 z-40 hidden translate-y-0 border-t border-line/70 px-3 pt-3 shadow-[0_-10px_30px_-18px_rgba(10,47,36,0.4)]"
    style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom))"
  >
    <a href={SITE.telegram} class="btn btn-primary w-full py-3.5">
      {dict.sticky.cta}
      <span aria-hidden="true" class="btn-arrow">→</span>
    </a>
  </div>
</div>

<script>
  const bar = document.getElementById('sticky-cta');
  const hero = document.getElementById('hero');
  const contact = document.getElementById('contact');
  if (bar && hero) {
    let heroGone = false;
    let contactVisible = false;
    const update = () => bar.classList.toggle('hidden', !heroGone || contactVisible);
    // Беремо останній запис: при швидкому скролі зміни приходять пачкою
    new IntersectionObserver((entries) => {
      heroGone = !entries[entries.length - 1].isIntersecting;
      update();
    }).observe(hero);
    if (contact)
      new IntersectionObserver((entries) => {
        contactVisible = entries[entries.length - 1].isIntersecting;
        update();
      }).observe(contact);
  }
</script>
