---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { pick, t, type Lang } from '../i18n';
import Layout from '../layouts/Layout.astro';
import VideoFacade from './VideoFacade.astro';

interface Props {
  lang: Lang;
  entry: CollectionEntry<'cases'>;
}

const { lang, entry } = Astro.props;
const dict = t(lang);
const { data } = entry;
const home = lang === 'en' ? '/en/' : '/';
const metaTitle = `${data.business.name}: ${pick(lang, data.result)}`;
const quote = pick(lang, data.testimonial.quote).trim();
const showTestimonial = quote.length > 0;
const blocks = [
  { label: dict.cases.problem, text: pick(lang, data.problem) },
  { label: dict.cases.solution, text: pick(lang, data.solution) },
];
---

<Layout lang={lang} title={metaTitle} description={pick(lang, data.problem).slice(0, 155)}>
  <article class="mx-auto w-full max-w-3xl px-5 py-12 md:px-8 md:py-16">
    <a href={`${home}#cases`} class="text-sm font-medium text-accent hover:underline">← {dict.cases.back}</a>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <p class="text-sm font-medium text-muted">
        {pick(lang, data.business.niche)} · {pick(lang, data.business.city)}
      </p>
    </div>
    <h1 class="mt-2 text-h2 font-bold text-balance">{data.business.name}</h1>
    <p class="mt-4 flex items-start gap-3 text-h3 font-semibold text-accent text-balance">
      <span aria-hidden="true" class="mt-2.5 h-2.5 w-2.5 shrink-0 rounded-full bg-brass"></span>
      <span>{pick(lang, data.result)}</span>
    </p>

    <Image
      src={data.cover}
      alt={data.business.name}
      widths={[640, 960, 1400]}
      sizes="(min-width: 768px) 720px, 100vw"
      class="mt-8 aspect-video w-full rounded-3xl border border-line object-cover"
      loading="eager"
    />

    {
      data.liveUrl && (
        <a
          href={data.liveUrl}
          target="_blank"
          rel="noopener"
          class="mt-8 inline-flex items-center gap-2 rounded-full border border-accent px-6 py-3 font-medium text-accent transition-colors hover:bg-accent hover:text-white"
        >
          {dict.cases.live}
          <span aria-hidden="true">↗</span>
        </a>
      )
    }

    {
      blocks.map((block) => (
        <section class="mt-10">
          <h2 class="text-sm font-medium tracking-wide text-muted uppercase">{block.label}</h2>
          <p class="mt-3 text-lead leading-relaxed whitespace-pre-line">{block.text.trim()}</p>
        </section>
      ))
    }

    {
      showTestimonial && (
        <section class="mt-10">
          <h2 class="text-sm font-medium tracking-wide text-muted uppercase">{dict.cases.ownerSays}</h2>
          <figure class="mt-4 rounded-3xl border border-line bg-card p-7 shadow-sm">
            {data.testimonial.video && (
              <div class="mb-6">
                <VideoFacade lang={lang} videoId={data.testimonial.video} label={data.business.name} />
              </div>
            )}
            <blockquote class="text-lead leading-relaxed whitespace-pre-line">
              «{quote}»
              {lang === 'en' && data.testimonial.originalLang === 'ua' && (
                <span class="mt-2 block text-xs text-muted">Translated from Ukrainian</span>
              )}
            </blockquote>
            <figcaption class="mt-5 flex items-center gap-3">
              <Image
                src={data.owner.photo}
                alt={data.owner.name}
                widths={[96]}
                sizes="48px"
                class="h-12 w-12 rounded-full object-cover"
                loading="lazy"
              />
              <div>
                <p class="font-medium">{data.owner.name}</p>
                <p class="text-sm text-muted">{data.business.name}</p>
              </div>
            </figcaption>
          </figure>
        </section>
      )
    }

    {
      data.gallery.length > 0 && (
        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {data.gallery.map((img) => (
            <Image
              src={img}
              alt={data.business.name}
              widths={[400, 640]}
              sizes="(min-width: 640px) 350px, 100vw"
              class="w-full rounded-2xl object-cover"
              loading="lazy"
            />
          ))}
        </div>
      )
    }

    <div class="mt-12 rounded-3xl bg-accent-deep p-8 text-center md:p-10">
      <p class="text-h3 font-semibold text-white text-balance">{dict.final.title}</p>
      <a
        href={`${home}#contact`}
        class="mt-5 inline-flex items-center justify-center rounded-full bg-white px-7 py-3.5 font-medium text-accent transition-colors hover:bg-accent-soft"
        >{dict.final.cta}</a
      >
    </div>
  </article>
</Layout>
