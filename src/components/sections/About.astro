---
import { Image } from 'astro:assets';
import { SITE } from '../../site.config.mjs';
import { t, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = t(lang);
const fullName = lang === 'en' ? `${SITE.nameEn} ${SITE.surnameEn}` : `${SITE.name} ${SITE.surname}`;

// Окреме фото для «Про мене» (roman-about.*), інакше — те саме, що в hero (roman.*).
const aboutPhotos = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/roman-about.{jpg,jpeg,png,webp}',
  { eager: true },
);
const heroPhotos = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/roman.{jpg,jpeg,png,webp,svg}',
  { eager: true },
);
const photo = Object.values(aboutPhotos)[0]?.default ?? Object.values(heroPhotos)[0]?.default;
---

<section id="about" class="mx-auto w-full max-w-5xl scroll-mt-24 px-5 pb-24 md:px-8 md:pb-32">
  <div class="border-t border-line/80 pt-14 md:pt-20">
    <div class="grid items-start gap-12 md:grid-cols-[minmax(0,20rem)_1fr] md:gap-14 lg:grid-cols-[minmax(0,22rem)_1fr] lg:gap-20">
      <!-- Портрет: латунна рамка-офсет + підпис, як у журнальному матеріалі -->
      {
        photo && (
          <figure class="reveal relative mx-auto w-72 max-w-full md:mx-0 md:w-full">
            <div
              aria-hidden="true"
              class="absolute inset-0 translate-x-4 translate-y-4 rounded-[2rem] border border-brass/45"
            />
            <div class="portrait-panel relative aspect-3/4 overflow-hidden rounded-[2rem] shadow-[var(--shadow-portrait)] ring-1 ring-ink/10">
              <Image
                src={photo}
                alt={dict.hero.photoAlt}
                widths={[320, 440, 640]}
                sizes="(min-width: 1024px) 352px, (min-width: 768px) 320px, 288px"
                class="reveal-img absolute inset-0 h-full w-full object-cover"
                loading="lazy"
              />
              <div
                aria-hidden="true"
                class="absolute inset-0 bg-gradient-to-t from-ink/60 via-ink/10 to-transparent"
              />
              <figcaption class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-3 p-5 text-white">
                <div>
                  <p class="font-display text-lg leading-tight font-semibold">{fullName}</p>
                  <p class="mt-0.5 text-xs text-white/75">{dict.about.signoffRole}</p>
                </div>
                <svg viewBox="0 0 110 12" class="mb-1 h-3 w-20 shrink-0 text-brass-soft" fill="none" aria-hidden="true">
                  <path d="M2 7C18 2 33 10 52 5s34-5 56 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </figcaption>
            </div>
          </figure>
        )
      }

      <!-- Текст: редакційна колонка з видiленою ключовою фразою -->
      <div data-stagger="90" class="max-w-2xl">
        <span class="kicker reveal">{dict.about.kicker}</span>
        <h2 class="reveal mt-4 text-h2 font-bold text-balance">{dict.about.title}</h2>
        <p class="reveal mt-6 text-lead leading-relaxed text-muted">{dict.about.text}</p>

        <ul class="mt-8 grid gap-3.5">
          {
            dict.about.points.map((point) => (
              <li class="reveal flex gap-3">
                <span
                  aria-hidden="true"
                  class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-accent/12 text-accent"
                >
                  <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                </span>
                <span class="leading-relaxed">{point}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <p class="reveal mt-10 max-w-[760px] border-l-2 border-brass/60 pl-5 font-display text-h3 font-semibold text-balance text-accent md:mt-12">
      {dict.about.pullQuote}
    </p>
  </div>
</section>
