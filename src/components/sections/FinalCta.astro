---
import { SITE } from '../../site.config.mjs';
import { t, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = t(lang);
const inputClass =
  'rounded-xl border border-line bg-bg px-4 py-2.5 text-ink outline-none transition-[border-color,box-shadow] duration-200 placeholder:text-muted/70 focus:border-accent focus:ring-2 focus:ring-accent/25';

// Показуємо лише ті месенджери, для яких заповнене посилання в site.config.mjs.
const messengers = [
  { label: 'Telegram', href: SITE.telegram },
  { label: 'WhatsApp', href: SITE.whatsapp },
  { label: 'Viber', href: SITE.viber },
].filter((m) => m.href);
---

<section id="contact" class="relative scroll-mt-24 overflow-hidden bg-ink-deep">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    <div class="dotgrid absolute inset-0 opacity-[0.06] invert"></div>
    <div class="glow-accent absolute -top-24 left-1/2 h-[36rem] w-[36rem] -translate-x-1/2 rounded-full opacity-60"></div>
    <div class="glow-brass absolute bottom-[-20%] right-[-8%] h-[28rem] w-[28rem] rounded-full opacity-25"></div>
  </div>

  <div class="relative mx-auto grid w-full max-w-6xl items-start gap-12 px-5 py-20 md:grid-cols-2 md:gap-16 md:px-8 md:py-28 lg:gap-20">
    <!-- Ліва колонка: текст і месенджери -->
    <div>
      <div class="reveal mb-7 w-fit">
        <div class="notif float-soft">
          <span class="font-medium text-ink">{dict.final.notif}</span>
        </div>
      </div>

      <span class="kicker reveal" style="color: var(--color-brass-soft)">{dict.final.contactKicker}</span>
      <h2 class="reveal mt-4 text-h2 font-bold text-balance text-white">{dict.final.contactTitle}</h2>
      <p class="reveal mt-4 max-w-md text-lead text-white/75">{dict.final.contactText}</p>

      {
        messengers.length > 0 && (
          <div class="reveal mt-8 flex flex-wrap gap-3">
            {messengers.map((m) => (
              <a
                href={m.href}
                class="inline-flex items-center gap-2 rounded-full border border-white/25 px-6 py-3 font-medium text-white transition-colors hover:border-white/50 hover:bg-white/10"
              >
                {m.label}
              </a>
            ))}
          </div>
        )
      }

      <p class="reveal mt-6 text-sm text-white/55">{dict.final.messengersNote}</p>
    </div>

    <!-- Права колонка: форма -->
    <form
      method="POST"
      action="/api/lead"
      class="reveal grid gap-2.5 rounded-[1.5rem] bg-card p-6 text-left shadow-[var(--shadow-lift)] md:p-7"
    >
      <input type="hidden" name="lang" value={lang} />
      {/* Пастка для ботів: людина цього поля не бачить */}
      <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" />
      <label class="grid gap-1">
        <span class="text-sm font-medium">{dict.final.form.name}</span>
        <input type="text" name="name" required maxlength="100" autocomplete="name" class={inputClass} />
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium">{dict.final.form.contact}</span>
        <input type="text" name="phone" required maxlength="100" class={inputClass} />
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium">{dict.final.form.biz}</span>
        <input type="text" name="biz" maxlength="200" placeholder={dict.final.form.bizPlaceholder} class={inputClass} />
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium">{dict.final.form.task}</span>
        <textarea name="task" rows="3" maxlength="600" placeholder={dict.final.form.taskPlaceholder} class={`${inputClass} resize-y`}></textarea>
      </label>
      <button type="submit" class="btn btn-primary mt-1.5 px-7 py-3.5">{dict.final.form.submit}</button>
    </form>
  </div>
</section>
