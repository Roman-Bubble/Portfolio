---
import { t, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = t(lang);
---

<section id="how" class="mx-auto w-full max-w-6xl scroll-mt-24 px-5 pt-20 pb-8 md:px-8 md:pt-28 md:pb-12">
  <div class="max-w-2xl">
    <span class="kicker reveal">{dict.process.kicker}</span>
    <h2 class="reveal mt-4 text-h2 font-bold text-balance">{dict.process.title}</h2>
    <p class="reveal mt-4 text-lead text-muted">{dict.process.sub}</p>
  </div>

  <ol data-stagger="120" class="relative mt-16 grid gap-x-6 gap-y-12 md:grid-cols-4">
    <div
      aria-hidden="true"
      class="absolute inset-x-0 top-[26px] hidden h-px bg-gradient-to-r from-transparent via-line to-transparent md:block"
    >
    </div>
    {
      dict.process.steps.map((step, i) => (
        <li class="reveal relative">
          <div class="flex items-center gap-4 md:block">
            <span class="relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-accent font-display text-base leading-none font-semibold tabular-nums text-brass-soft shadow-[var(--shadow-card)] ring-4 ring-bg">
              <span class="translate-y-px">{`0${i + 1}`}</span>
            </span>
            <h3 class="text-h3 font-semibold tracking-tight md:mt-6">{step.title}</h3>
          </div>
          <p class="mt-2.5 text-[0.95rem] leading-relaxed text-muted md:pr-5">{step.text}</p>
        </li>
      ))
    }
  </ol>
</section>
